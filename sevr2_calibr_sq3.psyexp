    <LoopInitiator loopType="TrialHandler" name="BJW_trials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'Text': 'Я считаю, что, по большому счету, заслуживаю того, что происходит со мной.'}, {'Text': 'Как правило, жизнь ко\xa0мне справедлива.'}, {'Text': 'Я верю, что обычно получаю то, что заслуживаю.'}, {'Text': 'В моей жизни в\xa0общем и\xa0целом всё происходит справедливо.'}, {'Text': 'В моей жизни несправедливость – скорее исключение, чем правило.'}, {'Text': 'Я считаю, что в\xa0целом в\xa0моей жизни всё справедливо.'}, {'Text': 'Я думаю, что важные решения, которые касаются меня, обычно справедливы.'}, {'Text': 'Я считаю, что в\xa0целом мир справедлив.'}, {'Text': 'Я считаю, что, по\xa0большому счету, люди получают то, что заслуживают.'}, {'Text': 'Я уверен, что справедливость всегда побеждает несправедливость.'}, {'Text': 'Я убежден, что, если человек пережил несправедливость, в\xa0будущем это возместится.'}, {'Text': 'Я твердо уверен, что несправедливость в\xa0самых разных жизненных ситуациях (в семье, учебе и\xa0т. д.) – скорее исключение, чем правило.'}, {'Text': 'Я думаю, что все, кто принимает важные решения, стремятся быть справедливыми.'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="BJW.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
