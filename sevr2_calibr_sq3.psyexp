      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="loop_L" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="task_L"/>
    <Routine name="fb_task"/>
    <LoopTerminator name="loop_L"/>
    <LoopInitiator loopType="TrialHandler" name="l_slid">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'q_sl': 'Это было сложно?'}, {'q_sl': 'Вы могли контролировать ситуацию?'}, {'q_sl': 'Насколько результат зависел от Вас?'}, {'q_sl': 'Насколько успешно получалось сравнивать квадраты?'}, {'q_sl': 'Вы довольны результатом?'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="tabl_sl.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="l_slid" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="slider"/>
    <LoopTerminator name="l_slid"/>
    <Routine name="fin_sum"/>
    <Routine name="Get_points"/>
    <Routine name="thanks"/>
  </Flow>
</PsychoPy2experiment>
